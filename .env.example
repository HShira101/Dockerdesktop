# ─────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────
# Nombre visible de la app
APP_NAME=Laravel
# Entorno: local | production
APP_ENV=local
# Clave de cifrado (generar con: php artisan key:generate)
APP_KEY=
# Mostrar errores detallados (poner false en producción)
APP_DEBUG=true
# URL base de acceso
APP_URL=http://localhost

# ─────────────────────────────────────────
# IDIOMA
# ─────────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ─────────────────────────────────────────
# MANTENIMIENTO
# ─────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Rondas de cifrado para contraseñas (más alto = más seguro, más lento)
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Nivel mínimo de log: debug | info | warning | error
LOG_LEVEL=debug

# ─────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────
# Este proyecto usa SQLite (archivo local dentro del contenedor)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ─────────────────────────────────────────
# SESIÓN
# ─────────────────────────────────────────
# Driver de sesión (database guarda sesiones en SQLite)
SESSION_DRIVER=database
# Tiempo máximo de sesión en minutos (el middleware CheckSession aplica 10 min de inactividad)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─────────────────────────────────────────
# SERVICIOS INTERNOS
# ─────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# ─────────────────────────────────────────
# SERVICIOS EXTERNOS (no usados en este proyecto)
# ─────────────────────────────────────────
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# CORREO (no activo, solo para posible reset de contraseña)
# ─────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# AWS (no usado en este proyecto)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────
# VITE (assets del frontend)
# ─────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# USUARIO INICIAL (usado por DatabaseSeeder al hacer db:seed)
# ─────────────────────────────────────────
# Nombre real del usuario
SEED_NOMBRE="Nombre completo"
# Alias con el que se mostrará en la interfaz
SEED_ALIAS="Alias"
# Correo para login y recuperación de contraseña
SEED_CORREO="correo@ejemplo.com"
# Contraseña inicial (cambiar tras el primer acceso)
SEED_PASSWORD="contraseña_segura"
